<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Suivi de Navire Segmenté - SAS VA</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        #map { height: 100vh; width: 100vw; background: #0f172a; }
        .info-box { font-size: 13px; min-width: 200px; }
        .header { font-weight: bold; color: #38bdf8; border-bottom: 1px solid #ddd; margin-bottom: 5px; padding-bottom: 5px; text-transform: uppercase; }
    </style>
</head>
<body>

    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/leaflet-rotatedmarker@0.2.0/leaflet.rotatedMarker.min.js"></script>

    <script>
        // 1. Initialisation de la carte avec un fond sombre élégant
        const map = L.map('map').setView([0, 0], 2);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap &copy; CARTO'
        }).addTo(map);

        let pathLayer = L.featureGroup().addTo(map);

        function onMessage(event) {
            if (event.data && event.data.data) {
                drawVesselPath(event.data);
            }
        }

        function drawVesselPath(sasPayload) {
            pathLayer.clearLayers();
            const rows = sasPayload.data;
            if (rows.length === 0) return;

            let currentSegment = [];
            const allSegments = [];
            const threshold = 5; // Seuil de distance en degrés (si > 5°, on considère que c'est un nouveau trajet)

            rows.forEach((row, index) => {
                const lat = row[0];
                const lng = row[1];

                // Vérification du saut de distance pour éviter les lignes traversantes
                if (currentSegment.length > 0) {
                    const lastPoint = currentSegment[currentSegment.length - 1];
                    const distance = Math.sqrt(Math.pow(lat - lastPoint[0], 2) + Math.pow(lng - lastPoint[1], 2));
                    
                    if (distance > threshold) {
                        allSegments.push(currentSegment); // On sauvegarde le segment fini
                        currentSegment = []; // On en commence un nouveau
                    }
                }
                
                currentSegment.push([lat, lng]);

                // Gestion du marqueur pour le point final (la position actuelle)
                if (index === rows.length - 1) {
                    createShipMarker(row);
                }
            });
            
            // Ajouter le dernier segment
            allSegments.push(currentSegment);

            // 2. Dessiner tous les segments proprement
            allSegments.forEach(segment => {
                if (segment.length > 1) {
                    L.polyline(segment, {
                        color: '#38bdf8',
                        weight: 3,
                        opacity: 0.8,
                        lineJoin: 'round'
                    }).addTo(pathLayer);
                }
            });

            // Ajuster la vue
            if (pathLayer.getBounds().isValid()) {
                map.fitBounds(pathLayer.getBounds(), { padding: [50, 50] });
            }
        }

        function createShipMarker(data) {
            const [lat, lng, heading, sog, cog, type, dwt, rot] = data;

            const shipIcon = L.divIcon({
                html: `<svg viewBox="0 0 24 24" width="34" height="34" fill="#4ade80" style="filter: drop-shadow(0px 0px 5px rgba(0,0,0,0.5));">
                        <path d="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"/></svg>`,
                className: '',
                iconSize: [34, 34],
                iconAnchor: [17, 17]
            });

            const marker = L.marker([lat, lng], { 
                icon: shipIcon,
                rotationAngle: heading
            }).addTo(pathLayer);

            marker.bindPopup(`
                <div class="info-box">
                    <div class="header">${type || 'Navire'}</div>
                    <b>Vitesse :</b> ${sog?.toFixed(2) || 0} kts<br>
                    <b>Route (COG) :</b> ${cog?.toFixed(1) || 0}°<br>
                    <b>Cap (Heading) :</b> ${heading?.toFixed(1) || 0}°<br>
                    <b>Rotation :</b> ${rot || 0}°/min<br>
                    <b>Tonnage :</b> ${dwt?.toLocaleString() || 0} DWT
                </div>
            `).openPopup();
        }

        window.addEventListener('message', onMessage, false);
    </script>
</body>
</html>
