<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Visualisation Données Brutes - SAS VA</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { margin: 0; padding: 0; }
        #map { height: 100vh; width: 100vw; background: #0f172a; }
        .raw-point {
            background-color: #00e676;
            border: 1px solid white;
            border-radius: 50%;
        }
    </style>
</head>
<body>
    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const map = L.map('map').setView([0, 0], 2);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);
        
        let dataLayer = L.featureGroup().addTo(map);

        function onMessage(event) {
            if (event.data && event.data.data) {
                renderRawData(event.data.data);
            }
        }

        function renderRawData(rows) {
            dataLayer.clearLayers();
            
            rows.forEach((row) => {
                const lat = row[0]; // Latitude
                const lng = row[1]; // Longitude
                
                // On crée un simple cercle pour chaque ligne de donnée reçue
                if (lat != null && lng != null) {
                    L.circleMarker([lat, lng], {
                        radius: 4,
                        fillColor: "#00e676",
                        color: "#fff",
                        weight: 1,
                        opacity: 1,
                        fillOpacity: 0.8
                    })
                    .bindPopup(`Lat: ${lat}<br>Lng: ${lng}<br>Data: ${JSON.stringify(row)}`)
                    .addTo(dataLayer);
                }
            });

            if (dataLayer.getLayers().length > 0) {
                map.fitBounds(dataLayer.getBounds(), { padding: [20, 20] });
            }
        }

        window.addEventListener('message', onMessage, false);
    </script>
</body>
</html>
