<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Suivi de Navire SAS VA</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { margin: 0; padding: 0; font-family: sans-serif; }
        #map { height: 100vh; width: 100vw; background: #041424; }
        .info-box { font-size: 12px; line-height: 1.4; }
        .vessel-stat { font-weight: bold; color: #2196F3; }
    </style>
</head>
<body>

    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/leaflet-rotatedmarker@0.2.0/leaflet.rotatedMarker.min.js"></script>

    <script>
        // 1. Initialisation de la carte
        const map = L.map('map').setView([0, 0], 2);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        let pathLayer = L.featureGroup().addTo(map);

        // 2. Fonction de réception des données SAS
        function onMessage(event) {
            if (event.data && event.data.data) {
                drawVesselPath(event.data);
            }
        }

        function drawVesselPath(sasPayload) {
            pathLayer.clearLayers();
            const rows = sasPayload.data;
            const coords = [];

            if (rows.length === 0) return;

            rows.forEach((row, index) => {
                // Mapping des index (doit correspondre à l'ordre dans SAS VA)
                const lat = row[0];
                const lng = row[1];
                const heading = row[2];
                const sog = row[3];
                const cog = row[4];
                const type = row[5];
                const dwt = row[6];
                const rot = row[7];

                coords.push([lat, lng]);

                // 3. Dessiner le marqueur du bateau (seulement pour la position actuelle/dernière ligne)
                if (index === rows.length - 1) {
                    const shipIcon = L.divIcon({
                        html: `<svg viewBox="0 0 24 24" width="30" height="30" fill="#00e676">
                                <path d="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"/></svg>`,
                        className: '',
                        iconSize: [30, 30],
                        iconAnchor: [15, 15]
                    });

                    const marker = L.marker([lat, lng], { 
                        icon: shipIcon,
                        rotationAngle: heading // Utilisation de trueheading
                    }).addTo(pathLayer);

                    marker.bindPopup(`
                        <div class="info-box">
                            <h3 style="margin:0 0 5px 0">${type}</h3>
                            <hr>
                            <b>Vitesse (SOG):</b> ${sog} nœuds<br>
                            <b>Route (COG):</b> ${cog}°<br>
                            <b>Cap (Heading):</b> ${heading}°<br>
                            <b>Rotation:</b> ${rot}°/min<br>
                            <b>Tonnage (DWT):</b> ${dwt} t
                        </div>
                    `).openPopup();
                }
            });

            // 4. Tracer la ligne de trajectoire
            const polyline = L.polyline(coords, {
                color: '#2196F3',
                weight: 3,
                opacity: 0.7,
                dashArray: '5, 10'
            }).addTo(pathLayer);

            // Ajuster la vue pour voir tout le trajet
            map.fitBounds(polyline.getBounds(), { padding: [20, 20] });
        }

        // Écouter les messages venant de SAS Visual Analytics
        window.addEventListener('message', onMessage, false);
    </script>
</body>
</html>
