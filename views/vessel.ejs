<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Suivi de Navire Temps Réel - SAS VA</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { margin: 0; padding: 0; font-family: sans-serif; }
        #map { height: 100vh; width: 100vw; background: #041424; }
        .info-box { font-size: 12px; line-height: 1.4; }
        .vessel-stat { font-weight: bold; color: #2196F3; }
    </style>
</head>
<body>

    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/leaflet-rotatedmarker@0.2.0/leaflet.rotatedMarker.min.js"></script>

    <script>
        const map = L.map('map').setView([0, 0], 2);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        let pathLayer = L.featureGroup().addTo(map);

        function onMessage(event) {
            if (event.data && event.data.data) {
                drawVesselPath(event.data);
            }
        }

        function drawVesselPath(sasPayload) {
            pathLayer.clearLayers();
            const rows = sasPayload.data;
            
            if (!rows || rows.length === 0) return;

            // 1. Trouver l'index de la ligne la plus récente basé sur la colonne datetime (Index 8)
            let mostRecentIndex = 0;
            let maxTime = 0;

            rows.forEach((row, index) => {
                // On convertit la valeur datetime en nombre pour comparer
                const currentTime = new Date(row[8]).getTime(); 
                if (currentTime > maxTime) {
                    maxTime = currentTime;
                    mostRecentIndex = index;
                }
            });

            const coords = [];

            rows.forEach((row, index) => {
                const lat = row[0];
                const lng = row[1];
                const heading = row[2];
                const sog = row[3];
                const cog = row[4];
                const type = row[5];
                const dwt = row[6];
                const rot = row[7];
                const dt = row[8]; // datetime

                coords.push([lat, lng]);

                // 2. N'afficher l'icône du bateau QUE pour la valeur datetime la plus récente
                if (index === mostRecentIndex) {
                    const shipIcon = L.divIcon({
                        html: `<svg viewBox="0 0 24 24" width="32" height="32" fill="#00e676">
                                <path d="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"/></svg>`,
                        className: '',
                        iconSize: [32, 32],
                        iconAnchor: [16, 16]
                    });

                    const marker = L.marker([lat, lng], { 
                        icon: shipIcon,
                        rotationAngle: heading 
                    }).addTo(pathLayer);

                    marker.bindPopup(`
                        <div class="info-box">
                            <h3 style="margin:0 0 5px 0">${type}</h3>
                            <div style="font-size:10px; color:#666; margin-bottom:5px;">📅 ${dt}</div>
                            <hr>
                            <b>Vitesse (SOG):</b> ${sog} nœuds<br>
                            <b>Route (COG):</b> ${cog}°<br>
                            <b>Cap (Heading):</b> ${heading}°<br>
                            <b>Tonnage:</b> ${dwt} t
                        </div>
                    `).openPopup();
                }
            });

            // 3. Tracer le sillage
            const polyline = L.polyline(coords, {
                color: '#2196F3',
                weight: 2,
                opacity: 0.6,
                dashArray: '5, 8'
            }).addTo(pathLayer);

            map.fitBounds(polyline.getBounds(), { padding: [30, 30] });
        }

        window.addEventListener('message', onMessage, false);
    </script>
</body>
</html>
