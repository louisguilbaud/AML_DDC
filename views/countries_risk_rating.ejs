<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AML Evaluation</title>

    <script src="./javascripts/sas/util/messagingUtil.js"></script>
    <script src="./javascripts/sas/util/jobExecutionUtil.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.1.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css">

    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        .container-box {
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            width: 700px;
            max-width: 90%;
            padding: 30px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }

        .form-control[disabled] {
            background: #f8f9fa;
            font-weight: 500;
            border: 1px solid #dee2e6;
            color: #333;
        }

        .risk-container {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #edf2f7;
        }

        .risk-btn {
            min-width: 130px;
            border-radius: 6px;
            font-weight: 500;
            transition: none;
        }

        /* Correction du contraste pour Medium Risk */
        .btn-outline-warning:hover, 
        .selected-risk.btn-outline-warning {
            color: white !important;
            background-color: #ffc107 !important;
        }

        .selected-risk {
            font-weight: 800 !important;
            border-width: 3px !important;
            color: white !important; /* Force le blanc sur tous les sélectionnés */
        }

        /* On remplit le fond quand c'est sélectionné */
        .selected-risk.btn-outline-success { background-color: #198754; }
        .selected-risk.btn-outline-warning { background-color: #ffc107; }
        .selected-risk.btn-outline-danger { background-color: #dc3545; }

        .col-form-label {
            color: #4a5568;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
        }
    </style>
</head>

<body>

    <div class="container-box">
        <form id="evaluation"></form>
    </div>

    <script>
        let selectedRisk = 0;

        const displayForm = (message) => {
            const formElements = message.columns.map((element, index) => {
                const label = element.label.replace("_", " ");
                return `
                <div class="row mb-3 align-items-center">
                    <label class="col-4 col-form-label fw-bold">${label}</label>
                    <div class="col-8">
                        <input type="text"
                               id="${element.name}"
                               name="${label}"
                               value="${message.data[0][index]}"
                               disabled
                               class="form-control">
                    </div>
                </div>
                `;
            });

            formElements.push(riskComponent("rating"));
            $("#evaluation").html(formElements.join(""));

            $(".risk-btn").on("click", function() {
                $(".risk-btn").removeClass("selected-risk");
                $(this).addClass("selected-risk");
                
                selectedRisk = $(this).data("value");
                executeEvaluation();
            });
        }

        function executeEvaluation() {
            const data = {};
        
            $("#evaluation input").each((index, element) => {
                data[element.name] = element.value;
            });
        
            data["AML RISK"] = selectedRisk;
        
            const url = "https://sasserver.demo.sas.com";
        
            const parametersEval = { 
                "_program": "/Public/countries_rating" 
            };
            
            const parametersDashboard = { 
                "_program": "/Public/update_tbml_dashboards" 
            };
            
            const parametersHighlight = { 
                "_program": "/Public/highlight_mt_messages" 
            };
            
            // 1. Appel du job principal
            executeJob(url, data, parametersEval)
                .then(response => {
            
                    console.log("Evaluation success:", response);
            
                    if (response.status && response.status !== "success") {
                        throw new Error("Evaluation failed");
                    }
            
                    // 2. Appel du job dashboard
                    return executeJob(url, {}, parametersDashboard);
                })
                .then(response => {
            
                    console.log("Dashboard updated:", response);
            
                    // 3. Appel du job highlight
                    return executeJob(url, {}, parametersHighlight);
                })
                .then(response => {
            
                    console.log("Highlight done:", response);
            
                })
                .catch(error => {
                    console.error("Error:", error);
                });
         }

        const riskComponent = (divID) => {
            return `
            <div id="${divID}" class="risk-container">
                <button type="button" class="btn btn-outline-success risk-btn" data-value="1">Low Risk</button>
                <button type="button" class="btn btn-outline-warning risk-btn" data-value="2">Medium Risk</button>
                <button type="button" class="btn btn-outline-danger risk-btn" data-value="3">High Risk</button>
            </div>
            `;
        }

        va.messagingUtil.setOnDataReceivedCallback(displayForm);
    </script>

</body>
</html>
