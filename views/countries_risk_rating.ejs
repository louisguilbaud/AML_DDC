<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>My DDC object</title>
  <meta name="description" content="A simple HTML file for my DDC object.">
  <script type="text/javascript" src="utils/messagingUtil.js"></script>
  <script type="text/javascript" src="utils/jobExecutionUtil.js"></script>

  <script src="https://code.jquery.com/jquery-3.6.1.min.js"
    integrity="sha256-o88AwQnZB+VDvE9tvIXrMQaPlFFSUTR+nldQm1LuPXQ="
    crossorigin="anonymous"></script>

  <!-- CSS only -->
  <link rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
    integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
    crossorigin="anonymous">

  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />

</head>

<style>

.selected-risk{
  box-shadow:0 0 8px rgba(0,0,0,0.4);
  transform:scale(1.05);
}

</style>

<body>

<form id="evaluation" class="container"></form>

<script>

let selectedRisk = 0

const displayForm = (message) => {

  // Generate the different form elements using the VA data
  const formElements = message.columns.map((element, index) => {

    const html =

      `
      <div class="row m-3">
          <label for="${element.name}" class="col-2">${element.label}</label>
          <input type="text"
          id="${element.name}"
          name="${element.label}"
          value="${message.data[0][index]}"
          disabled
          class="col">
      </div>
      `

    return html
  })

  // Add AML risk component
  formElements.push(riskComponent("rating"))

  // Add submit button
  formElements.push('<div class="row m-3"><button id="submitButton" type="submit" class="col btn btn-primary">Save evaluation</button></div>')

  // Add title
  formElements.unshift("<h1 class='row m-3 bg-primary p-3'>Evaluation</h1>")

  // Generate the form
  $("#evaluation").html(formElements.join(""))


  // Handle risk button click
  $(".risk-btn").on("click", function () {

    $(".risk-btn").removeClass("selected-risk")

    $(this).addClass("selected-risk")

    selectedRisk = $(this).data("value")

  })


  // Submit event
  $("#submitButton").on("click", (event) => {

    event.preventDefault()

    const data = {}

    $("#evaluation input").each((index, element) => {
      data[element.name] = element.value
    })

    data["AML_RISK"] = selectedRisk

    // Call the SAS Viya Job
    const url = "https://sasserver.demo.sas.com"

    const parameters = {
      "_program": "/Public/countries_rating",
    }

    executeJob(url, data, parameters).then(response => console.log(response))

    $(".risk-btn").removeClass("selected-risk")
    selectedRisk = 0

  })
}


// AML Risk component
const riskComponent = (divID) => {

  return `
  <div id=${divID} class="row m-3">

      <div class="col-2">
          AML Risk
      </div>

      <div class="col">

          <button type="button"
          class="btn btn-success risk-btn"
          data-value="1">
          Low Risk
          </button>

          <button type="button"
          class="btn btn-warning risk-btn"
          data-value="2">
          Medium Risk
          </button>

          <button type="button"
          class="btn btn-danger risk-btn"
          data-value="3">
          High Risk
          </button>

      </div>

  </div>
  `
}

va.messagingUtil.setOnDataReceivedCallback(displayForm)

</script>

</body>

</html>
