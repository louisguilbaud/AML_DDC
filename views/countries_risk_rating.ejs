<!doctype html>
<html lang="en">

<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>My DDC object</title>

<script src="utils/messagingUtil.js"></script>
<script src="utils/jobExecutionUtil.js"></script>

<script src="https://code.jquery.com/jquery-3.6.1.min.js"></script>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css">

</head>

<style>

body{
background:#f5f6fa;
}

.selected-risk{
box-shadow:0 0 8px rgba(0,0,0,0.4);
transform:scale(1.05);
}

.risk-btn{
margin-right:10px;
min-width:130px;
}

.form-control{
background:#f8f9fa;
}

</style>

<body>

<form id="evaluation" class="container mt-4"></form>

<script>

const displayForm = (message) => {

const formElements = message.columns.map((element, index) => {

return `
<div class="mb-3">

<label class="form-label fw-bold">${element.label}</label>

<input
type="text"
id="${element.name}"
name="${element.label}"
value="${message.data[0][index]}"
disabled
class="form-control">

</div>
`

})

formElements.push(riskComponent("rating"))

formElements.unshift("<h1 class='bg-primary text-white p-3 mb-4 rounded'>Evaluation</h1>")

$("#evaluation").html(formElements.join(""))

$(".risk-btn").on("click", function(){

$(".risk-btn").removeClass("selected-risk")

$(this).addClass("selected-risk")

const selectedRisk = $(this).data("value")

executeEvaluation(selectedRisk)

})

}


function executeEvaluation(selectedRisk){

const data = {}

$("#evaluation input").each((index, element) => {
data[element.name] = element.value
})

data["AML_RISK"] = selectedRisk

const url = "https://sasserver.demo.sas.com"

const parameters = {
"_program": "/Public/countries_rating"
}

executeJob(url, data, parameters).then(response => console.log(response))

}


const riskComponent = (divID) => {

return `
<div class="mb-3">

<label class="form-label fw-bold">AML Risk</label>

<div>

<button
type="button"
class="btn btn-success risk-btn"
data-value="1">
Low Risk
</button>

<button
type="button"
class="btn btn-warning risk-btn"
data-value="2">
Medium Risk
</button>

<button
type="button"
class="btn btn-danger risk-btn"
data-value="3">
High Risk
</button>

</div>

</div>
`

}

va.messagingUtil.setOnDataReceivedCallback(displayForm)

</script>

</body>

</html>
