<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AML Evaluation</title>

    <script src="./javascripts/sas/util/messagingUtil.js"></script>
    <script src="./javascripts/sas/util/jobExecutionUtil.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.1.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css">

    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            background: #f4f7f9; /* Fond légèrement gris pour faire ressortir la box */
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        .container-box {
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            width: 700px;
            max-width: 90%;
            padding: 40px;
            max-height: 90vh; 
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .form-control[disabled] {
            background: #f8f9fa;
            font-weight: 500;
            border: 1px solid #dee2e6;
            color: #333;
        }

        .risk-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            margin-top: 30px;
            padding-top: 25px;
            border-top: 1px solid #edf2f7;
        }

        /* Style Premium pour les boutons sélectionnés */
        .selected-risk {
            box-shadow: 0 0 0 3px rgba(0,0,0,0.1), inset 0 0 10px rgba(0,0,0,0.1);
            transform: scale(1.05);
            font-weight: bold;
        }

        .risk-btn {
            min-width: 130px;
            transition: all 0.2s ease-in-out;
            border-radius: 6px;
        }

        /* Loader discret et aligné */
        .loader-circle {
            width: 26px;
            height: 26px;
            border: 3px solid #f3f3f3;
            border-top: 3px solid #0d6efd;
            border-radius: 50%;
            display: none; /* Géré par jQuery fadeIn/fadeOut */
            animation: spin 0.8s linear infinite;
            margin-right: 10px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Labels plus lisibles */
        .col-form-label {
            color: #4a5568;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
        }
    </style>
</head>

<body>

    <div class="container-box">
        <form id="evaluation"></form>
    </div>

    <script>
        let selectedRisk = 0;

        const displayForm = (message) => {
            const formElements = message.columns.map((element, index) => {
                const label = element.label.replace("_", " ");
                return `
                <div class="row mb-3 align-items-center">
                    <label class="col-4 col-form-label fw-bold">${label}</label>
                    <div class="col-8">
                        <input type="text"
                               id="${element.name}"
                               name="${label}"
                               value="${message.data[0][index]}"
                               disabled
                               class="form-control shadow-sm">
                    </div>
                </div>
                `;
            });

            formElements.push(riskComponent("rating"));
            $("#evaluation").html(formElements.join(""));

            $(".risk-btn").on("click", function() {
                $(".risk-btn").removeClass("selected-risk");
                $(this).addClass("selected-risk");
                selectedRisk = $(this).data("value");

                // Affichage du loader
                $(".loader-circle").fadeIn(200);

                executeEvaluation();
            });
        }

        function executeEvaluation() {
            const data = {};
            $("#evaluation input").each((index, element) => {
                data[element.name] = element.value;
            });
            data["AML RISK"] = selectedRisk;

            const url = "https://sasserver.demo.sas.com";
            const parameters = { "_program": "/Public/countries_rating" };

            executeJob(url, data, parameters)
                .then(response => console.log("Success:", response))
                .catch(error => console.error("Error:", error))
                .finally(() => {
                    // Arrêt du loader dès que la réponse arrive (succès ou erreur)
                    $(".loader-circle").fadeOut(200);
                });
        }

        const riskComponent = (divID) => {
            return `
            <div id="${divID}" class="risk-container">
                <div class="loader-circle"></div>
                <button type="button" class="btn btn-outline-success risk-btn" data-value="1">Low Risk</button>
                <button type="button" class="btn btn-outline-warning risk-btn" data-value="2">Medium Risk</button>
                <button type="button" class="btn btn-outline-danger risk-btn" data-value="3">High Risk</button>
            </div>
            `;
        }

        va.messagingUtil.setOnDataReceivedCallback(displayForm);
    </script>

</body>
</html>
